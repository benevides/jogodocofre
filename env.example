# API LLM (OpenAI-compatible)
# Exemplos de APIs que funcionam:
#   - OpenAI: https://api.openai.com/v1/chat/completions
#   - Local (Ollama, etc): http://localhost:8000/v1/chat/completions
#   - Anthropic: https://api.anthropic.com/v1/messages

API_URL=http://localhost:8000/v1/chat/completions

# Chave de API (se necessário)
# Para OpenAI: sk-...
# Para Anthropic: sk-ant-...
# Para local (Ollama): deixa em branco ou 'local'
API_KEY=sua-chave-aqui

# Qual modelo usar
API_MODEL=model

# Porta do server.py (padrão: 5002)
COFRE_PORT=5002

# Servidor do Cofre (usado pelo agente.py — se mudar COFRE_PORT, mude aqui também)
COFRE_SERVER=http://localhost:5002

# Verbose (true/false)
VERBOSE=true
